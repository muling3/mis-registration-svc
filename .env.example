NODE_ENV=development
PORT=3002

# Wire these as features land (see architecture/06, 03, 08):
# Schema-per-service against the shared mis_core DB (arch §2, §3).
# DATABASE_URL is the runtime URL (via pgBouncer in prod, direct locally).
# DIRECT_DATABASE_URL bypasses pgBouncer for `prisma migrate` (Prisma's
# `_prisma_migrations` table lives in the schema named below, so each
# service's migration history is fully isolated from its peers).
DATABASE_URL=postgresql://mis:mis@localhost:5432/mis_core?schema=registration
DIRECT_DATABASE_URL=postgresql://mis:mis@localhost:5432/mis_core?schema=registration
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:29092
AUTH_JWKS_URI=http://localhost:3001/.well-known/jwks.json
LOG_LEVEL=debug
